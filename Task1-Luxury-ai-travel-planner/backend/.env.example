# ================================================================
# Luxy Travel Persona — Backend Environment Configuration
# ================================================================
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control.
# ================================================================

# AI Provider Selection
# Options: demo | claude | gemini
# - demo: Uses intelligent built-in responses (no API key needed)
# - claude: Uses Anthropic Claude API (requires CLAUDE_API_KEY)
# - gemini: Uses Google Gemini API (requires GEMINI_API_KEY)
AI_PROVIDER=demo

# Anthropic Claude API Key
# Get your key at: https://console.anthropic.com
# Leave blank if not using Claude
CLAUDE_API_KEY=

# Google Gemini API Key
# Get your key at: https://makersuite.google.com/app/apikey
# Leave blank if not using Gemini
GEMINI_API_KEY=
