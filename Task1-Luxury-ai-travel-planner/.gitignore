# ─────────────────────────────────────────────────────────────────
# ENVIRONMENT & CONFIG
# ─────────────────────────────────────────────────────────────────

# Environment files (NEVER commit these)
.env
.env.local
.env.*.local
.env.production
.env.staging
backend/.env
frontend/.env

# Secrets
secrets/
.secrets/
*.pem
*.key
*.crt

# Local configuration
config.local.js
settings.local.json
.env.local.js

# ─────────────────────────────────────────────────────────────────
# PROJECT SPECIFIC
# ─────────────────────────────────────────────────────────────────

# Backend specific
backend/venv/
backend/env/
backend/.env
backend/__pycache__/
backend/*.pyc
backend/instance/
backend/.webassets-cache

# Frontend specific
src/.env.local
.next/
.nuxt/
dist/
.cache/

# Local uploads (if applicable)
uploads/
temp/

# Database files (if applicable)
*.db
*.sqlite
*.sqlite3

# API keys and secrets
.keys/
keys.json
secrets.json

# Sensitive files
credentials.json
config.secret.json

# ─────────────────────────────────────────────────────────────────
# COMMON PROJECT FILES TO IGNORE
# ─────────────────────────────────────────────────────────────────

# ZIP archives
*.zip
*.rar
*.7z
*.tar.gz

# Backup files
*.bak
*.backup
*~

# Lock files (select based on your preference)
# Uncomment if you want to commit lock files
# package-lock.json
# yarn.lock
# Pipfile.lock

# macOS bundles
*.dmg
*.app

# ─────────────────────────────────────────────────────────────────
# EXCEPTIONS (Files/Folders to ALWAYS include)
# ─────────────────────────────────────────────────────────────────

# Use ! to negate the gitignore pattern

# Always include these config files
!.gitignore
!.gitattributes
!.env.example
!.env.example.backend
!.env.example.frontend

# Always include these documentation files
!README.md
!LICENSE
!CONTRIBUTING.md

# Always include these config files
!vite.config.ts
!tsconfig.json
!package.json
!backend/requirements.txt

# Always include example/template files
!.vscode/settings.json.example
!.vscode/launch.json.example

# ================================================================
# END OF GITIGNORE
# ================================================================
