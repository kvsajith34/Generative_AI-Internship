# ViralClip AI — Optional Environment Variables
# Copy this file to .env and fill in only the services you want to use.

# Optional: OpenAI API key for LLM-assisted content generation.
# If omitted, the app uses rule-based generation in demo/offline mode.
# OPENAI_API_KEY=sk-your-openai-key-here

# Optional: Anthropic API key for Claude-based generation.
# ANTHROPIC_API_KEY=sk-ant-your-claude-key-here

# Optional: Model name to use with the LLM client.
# OPENAI_MODEL=gpt-4o-mini
